# Copy to .env for Docker-based local development. Production instead keeps
# separate root-readable files at /etc/rssapp/staging.env and
# /etc/rssapp/production.env. Do not commit either real environment file.

# Local development builds from the working tree via compose.dev.yaml.
APP_IMAGE=rssapp:dev
APP_PORT=3000
POSTGRES_PORT=5433
POSTGRES_USER=rssapp
POSTGRES_PASSWORD=replace-with-a-local-password
POSTGRES_DB=rssapp
DATABASE_URL=postgres://rssapp:replace-with-a-local-password@db:5432/rssapp

# Generate with: npx auth secret
AUTH_SECRET=replace-with-a-long-random-secret
APP_URL=http://localhost:3000

# Optional account email delivery.
RESEND_API_KEY=
EMAIL_FROM=

# Optional Google sign-in. Create a Web application OAuth client and add
# https://<your-app-domain>/api/auth/callback/google as its redirect URI.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Optional browser push. Generate once per origin:
# npx web-push generate-vapid-keys --json
VAPID_SUBJECT=mailto:admin@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

SCHEDULER_TICK_MS=60000
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION=14
