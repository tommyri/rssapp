{
  "name": "currentfold",
  "version": "2026.7.3",
  "private": true,
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @currentfold/web",
    "build": "npm run build --workspace @currentfold/web",
    "start": "npm run start --workspace @currentfold/web",
    "lint": "npm run lint --workspace @currentfold/web",
    "format": "npm run format --workspace @currentfold/web",
    "test": "npm run test --workspace @currentfold/web",
    "db:generate": "npm run db:generate --workspace @currentfold/web",
    "db:migrate": "npm run db:migrate --workspace @currentfold/web",
    "db:studio": "npm run db:studio --workspace @currentfold/web",
    "reset-password": "npm run reset-password --workspace @currentfold/web",
    "set-owner": "npm run set-owner --workspace @currentfold/web",
    "brand:generate": "npm run generate --workspace @currentfold/brand",
    "brand:check": "npm run check --workspace @currentfold/brand",
    "contract:check": "npm run check --workspace @currentfold/api-contract",
    "deploy:check": "node scripts/check-compose-config.mjs",
    "ios:generate": "xcodegen generate --spec apps/ios/project.yml",
    "ios:lint": "swiftlint lint --config apps/ios/.swiftlint.yml --strict --no-cache",
    "ios:test": "apps/ios/scripts/test.sh",
    "release:prepare": "node scripts/prepare-release.mjs"
  }
}
