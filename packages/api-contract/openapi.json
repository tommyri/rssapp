{
  "openapi": "3.1.0",
  "jsonSchemaDialect": "https://json-schema.org/draft/2020-12/schema",
  "info": {
    "title": "Currentfold API",
    "version": "1.0.0",
    "description": "The stable first-party JSON API for Currentfold clients. Integer database keys are represented as opaque decimal strings on the wire."
  },
  "servers": [
    {
      "url": "/",
      "description": "The Currentfold installation serving this document"
    }
  ],
  "tags": [
    {
      "name": "Discovery"
    },
    {
      "name": "Account"
    },
    {
      "name": "Authentication"
    },
    {
      "name": "Reader"
    }
  ],
  "paths": {
    "/api/v1": {
      "get": {
        "operationId": "getServiceMetadata",
        "summary": "Discover this Currentfold API",
        "tags": ["Discovery"],
        "responses": {
          "200": {
            "description": "Service and capability metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceMetadataResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/openapi.json": {
      "get": {
        "operationId": "getOpenApiContract",
        "summary": "Download the OpenAPI contract",
        "tags": ["Discovery"],
        "responses": {
          "200": {
            "description": "OpenAPI 3.1 document",
            "content": {
              "application/vnd.oai.openapi+json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/session": {
      "post": {
        "operationId": "createNativeSession",
        "summary": "Sign in and create a native device session",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/NativeSignInRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "A new native device session",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NativeSessionResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/InvalidRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/AccountUnavailable" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      },
      "delete": {
        "operationId": "revokeNativeSession",
        "summary": "Sign out this native device session",
        "tags": ["Authentication"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "204": { "description": "The local session may be discarded" }
        }
      }
    },
    "/api/v1/auth/session/refresh": {
      "post": {
        "operationId": "refreshNativeSession",
        "summary": "Rotate a native refresh token",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/NativeRefreshRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "A rotated native credential pair",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NativeSessionResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/InvalidRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/auth/providers": {
      "get": {
        "operationId": "listNativeAuthProviders",
        "summary": "Discover native identity providers configured by this server",
        "tags": ["Authentication"],
        "responses": {
          "200": {
            "description": "Provider availability for this Currentfold installation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NativeAuthProvidersResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/providers/apple/challenge": {
      "post": {
        "operationId": "createNativeAppleChallenge",
        "summary": "Create a one-time nonce for Sign in with Apple",
        "tags": ["Authentication"],
        "responses": {
          "200": {
            "description": "A short-lived one-time Apple authentication challenge",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NativeAppleChallengeResponse"
                }
              }
            }
          },
          "404": { "$ref": "#/components/responses/AccountUnavailable" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/api/v1/auth/provider-session": {
      "post": {
        "operationId": "createNativeProviderSession",
        "summary": "Verify an Apple or Google identity and create a native device session",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NativeProviderSignInRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "A new native device session",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NativeSessionResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/InvalidRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/AccountUnavailable" },
          "409": { "$ref": "#/components/responses/AccountUnavailable" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/api/v1/auth/registration": {
      "post": {
        "operationId": "registerNativeAccount",
        "summary": "Create an account and send email verification",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NativeRegistrationRequest"
              }
            }
          }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/StatusMessage" },
          "201": { "$ref": "#/components/responses/StatusMessage" },
          "400": { "$ref": "#/components/responses/InvalidRequest" },
          "403": { "$ref": "#/components/responses/AccountUnavailable" },
          "409": { "$ref": "#/components/responses/AccountUnavailable" },
          "429": { "$ref": "#/components/responses/RateLimited" }
        }
      }
    },
    "/api/v1/auth/verification": {
      "post": {
        "operationId": "resendNativeVerification",
        "summary": "Request another email-verification link",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EmailRequest" }
            }
          }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/StatusMessage" },
          "400": { "$ref": "#/components/responses/InvalidRequest" }
        }
      },
      "patch": {
        "operationId": "verifyNativeEmail",
        "summary": "Consume an email-verification link token",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TokenRequest" }
            }
          }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/StatusMessage" },
          "400": { "$ref": "#/components/responses/InvalidRequest" }
        }
      }
    },
    "/api/v1/auth/recovery": {
      "post": {
        "operationId": "requestNativePasswordReset",
        "summary": "Request a password-reset link",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EmailRequest" }
            }
          }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/StatusMessage" },
          "400": { "$ref": "#/components/responses/InvalidRequest" }
        }
      },
      "patch": {
        "operationId": "resetNativePassword",
        "summary": "Consume a reset token and set a new password",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NativePasswordResetRequest"
              }
            }
          }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/StatusMessage" },
          "400": { "$ref": "#/components/responses/InvalidRequest" }
        }
      }
    },
    "/api/v1/me": {
      "get": {
        "operationId": "getCurrentAccount",
        "summary": "Get the authenticated account",
        "tags": ["Account"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "The authenticated account",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/api/v1/subscriptions": {
      "get": {
        "operationId": "listSubscriptions",
        "summary": "List the account's subscriptions",
        "tags": ["Reader"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Subscriptions in folder and title order",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["data"],
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Subscription"
                      }
                    }
                  },
                  "additionalProperties": false
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/api/v1/articles": {
      "get": {
        "operationId": "listArticles",
        "summary": "List articles newest first",
        "description": "Returns subscribed, non-muted articles. Pass nextCursor unchanged to continue from the prior page.",
        "tags": ["Reader"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 50
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "description": "Opaque continuation returned by the previous response.",
            "schema": {
              "type": "string",
              "maxLength": 512
            }
          },
          {
            "name": "unreadOnly",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "subscriptionId",
            "in": "query",
            "schema": {
              "$ref": "#/components/schemas/OpaqueId"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A keyset-paginated article page",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArticlePage"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/InvalidRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/api/v1/articles/read-state": {
      "patch": {
        "operationId": "updateArticleReadState",
        "summary": "Set read state for an article batch",
        "description": "This operation is idempotent. Every article must belong to a feed followed by the authenticated account.",
        "tags": ["Reader"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReadStateUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The resulting state and affected article IDs",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadStateResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/InvalidRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/ArticleNotFound"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "A short-lived native access token or a manually issued compatibility credential. First-party clients obtain and rotate native credentials through the authentication routes."
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "The bearer credential is absent, invalid, revoked, or belongs to an inactive account.",
        "headers": {
          "WWW-Authenticate": {
            "schema": {
              "type": "string"
            }
          }
        },
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "InvalidRequest": {
        "description": "A query parameter or JSON body is invalid.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "AccountUnavailable": {
        "description": "The account or registration state does not permit this operation.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "RateLimited": {
        "description": "The anonymous authentication attempt budget is exhausted.",
        "headers": {
          "Retry-After": {
            "schema": { "type": "integer", "minimum": 1 }
          }
        },
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "StatusMessage": {
        "description": "The account operation was accepted.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/StatusMessageResponse"
            }
          }
        }
      },
      "ArticleNotFound": {
        "description": "At least one article is not available to this account.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "OpaqueId": {
        "type": "string",
        "pattern": "^[1-9][0-9]*$",
        "examples": ["42"]
      },
      "ServiceMetadataResponse": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": {
            "type": "object",
            "required": [
              "name",
              "apiVersion",
              "productVersion",
              "capabilities",
              "links"
            ],
            "properties": {
              "name": {
                "const": "Currentfold"
              },
              "apiVersion": {
                "const": "v1"
              },
              "productVersion": {
                "type": "string"
              },
              "capabilities": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "links": {
                "type": "object",
                "required": ["openApi"],
                "properties": {
                  "openApi": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "NativeSignInRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string", "minLength": 1, "maxLength": 1024 },
          "deviceName": { "type": "string", "maxLength": 100 }
        },
        "additionalProperties": false
      },
      "NativeAuthProvidersResponse": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": {
            "type": "object",
            "required": ["apple", "google"],
            "properties": {
              "apple": { "type": "boolean" },
              "google": { "type": "boolean" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "NativeAppleChallengeResponse": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": {
            "type": "object",
            "required": ["challenge"],
            "properties": {
              "challenge": {
                "type": "string",
                "pattern": "^currentfold_challenge_",
                "maxLength": 128
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "NativeProviderSignInRequest": {
        "oneOf": [
          {
            "type": "object",
            "required": ["provider", "identityToken", "challenge"],
            "properties": {
              "provider": { "const": "apple" },
              "identityToken": {
                "type": "string",
                "minLength": 1,
                "maxLength": 16384
              },
              "challenge": {
                "type": "string",
                "minLength": 1,
                "maxLength": 128
              },
              "displayName": { "type": "string", "maxLength": 100 },
              "deviceName": { "type": "string", "maxLength": 100 },
              "inviteToken": { "type": "string", "maxLength": 256 }
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": ["provider", "identityToken"],
            "properties": {
              "provider": { "const": "google" },
              "identityToken": {
                "type": "string",
                "minLength": 1,
                "maxLength": 16384
              },
              "deviceName": { "type": "string", "maxLength": 100 },
              "inviteToken": { "type": "string", "maxLength": 256 }
            },
            "additionalProperties": false
          }
        ]
      },
      "NativeRegistrationRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string", "minLength": 8, "maxLength": 1024 },
          "inviteToken": { "type": "string" }
        },
        "additionalProperties": false
      },
      "EmailRequest": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": { "type": "string", "format": "email" }
        },
        "additionalProperties": false
      },
      "TokenRequest": {
        "type": "object",
        "required": ["token"],
        "properties": {
          "token": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      },
      "NativeRefreshRequest": {
        "type": "object",
        "required": ["refreshToken"],
        "properties": {
          "refreshToken": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      },
      "NativePasswordResetRequest": {
        "type": "object",
        "required": ["token", "password"],
        "properties": {
          "token": { "type": "string", "minLength": 1 },
          "password": { "type": "string", "minLength": 8, "maxLength": 1024 }
        },
        "additionalProperties": false
      },
      "NativeSessionResponse": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": {
            "type": "object",
            "required": ["account", "session"],
            "properties": {
              "account": { "$ref": "#/components/schemas/Account" },
              "session": {
                "type": "object",
                "required": [
                  "accessToken",
                  "accessTokenExpiresAt",
                  "refreshToken",
                  "refreshTokenExpiresAt"
                ],
                "properties": {
                  "accessToken": { "type": "string" },
                  "accessTokenExpiresAt": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "refreshToken": { "type": "string" },
                  "refreshTokenExpiresAt": {
                    "type": "string",
                    "format": "date-time"
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "StatusMessageResponse": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": {
            "type": "object",
            "required": ["message"],
            "properties": {
              "status": { "type": "string" },
              "message": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "AccountResponse": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/Account"
          }
        },
        "additionalProperties": false
      },
      "Account": {
        "type": "object",
        "required": ["id", "email", "displayName"],
        "properties": {
          "id": {
            "$ref": "#/components/schemas/OpaqueId"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "displayName": {
            "type": ["string", "null"]
          }
        },
        "additionalProperties": false
      },
      "Feed": {
        "type": "object",
        "required": ["id", "title", "url", "siteUrl"],
        "properties": {
          "id": {
            "$ref": "#/components/schemas/OpaqueId"
          },
          "title": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "siteUrl": {
            "type": ["string", "null"],
            "format": "uri"
          }
        },
        "additionalProperties": false
      },
      "Subscription": {
        "type": "object",
        "required": ["id", "title", "feed", "folder", "unreadCount", "paused"],
        "properties": {
          "id": {
            "$ref": "#/components/schemas/OpaqueId"
          },
          "title": {
            "type": "string"
          },
          "feed": {
            "type": "object",
            "required": ["id", "url", "siteUrl"],
            "properties": {
              "id": {
                "$ref": "#/components/schemas/OpaqueId"
              },
              "url": {
                "type": "string",
                "format": "uri"
              },
              "siteUrl": {
                "type": ["string", "null"],
                "format": "uri"
              }
            },
            "additionalProperties": false
          },
          "folder": {
            "oneOf": [
              {
                "type": "object",
                "required": ["id", "name"],
                "properties": {
                  "id": {
                    "$ref": "#/components/schemas/OpaqueId"
                  },
                  "name": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              },
              {
                "type": "null"
              }
            ]
          },
          "unreadCount": {
            "type": "integer",
            "minimum": 0
          },
          "paused": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "ArticleState": {
        "type": "object",
        "required": ["read", "starred", "readLater", "readingProgress"],
        "properties": {
          "read": {
            "type": "boolean"
          },
          "starred": {
            "type": "boolean"
          },
          "readLater": {
            "type": "boolean"
          },
          "readingProgress": {
            "type": ["number", "null"],
            "minimum": 0,
            "maximum": 1
          }
        },
        "additionalProperties": false
      },
      "Article": {
        "type": "object",
        "required": [
          "id",
          "subscriptionId",
          "title",
          "url",
          "canonicalUrl",
          "author",
          "publishedAt",
          "createdAt",
          "feed",
          "content",
          "audio",
          "state"
        ],
        "properties": {
          "id": {
            "$ref": "#/components/schemas/OpaqueId"
          },
          "subscriptionId": {
            "$ref": "#/components/schemas/OpaqueId"
          },
          "title": {
            "type": "string"
          },
          "url": {
            "type": ["string", "null"],
            "format": "uri"
          },
          "canonicalUrl": {
            "type": ["string", "null"],
            "format": "uri"
          },
          "author": {
            "type": ["string", "null"]
          },
          "publishedAt": {
            "type": ["string", "null"],
            "format": "date-time"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "feed": {
            "$ref": "#/components/schemas/Feed"
          },
          "content": {
            "type": "object",
            "required": ["html", "source"],
            "properties": {
              "html": {
                "type": ["string", "null"]
              },
              "source": {
                "type": "string",
                "enum": ["full", "feed"]
              }
            },
            "additionalProperties": false
          },
          "audio": {
            "oneOf": [
              {
                "type": "object",
                "required": ["url", "type"],
                "properties": {
                  "url": {
                    "type": "string",
                    "format": "uri"
                  },
                  "type": {
                    "type": ["string", "null"]
                  }
                },
                "additionalProperties": false
              },
              {
                "type": "null"
              }
            ]
          },
          "state": {
            "$ref": "#/components/schemas/ArticleState"
          }
        },
        "additionalProperties": false
      },
      "ArticlePage": {
        "type": "object",
        "required": ["data", "pagination"],
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Article"
            }
          },
          "pagination": {
            "type": "object",
            "required": ["nextCursor"],
            "properties": {
              "nextCursor": {
                "type": ["string", "null"]
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "ReadStateUpdate": {
        "type": "object",
        "required": ["articleIds", "read"],
        "properties": {
          "articleIds": {
            "type": "array",
            "minItems": 1,
            "maxItems": 100,
            "items": {
              "$ref": "#/components/schemas/OpaqueId"
            }
          },
          "read": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "ReadStateResponse": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/ReadStateUpdate"
          }
        },
        "additionalProperties": false
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": {
            "type": "object",
            "required": ["code", "message"],
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  }
