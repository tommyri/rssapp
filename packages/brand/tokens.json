{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "color": {
    "$type": "color",
    "paper": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0.980392, 0.976471, 0.960784],
        "hex": "#FAF9F5"
      }
    },
    "ink": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0.109804, 0.098039, 0.090196],
        "hex": "#1C1917"
      }
    },
    "current": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0.917647, 0.458824, 0.345098],
        "hex": "#EA7558"
      }
    },
    "stone": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0.470588, 0.443137, 0.423529],
        "hex": "#78716C"
      }
    },
    "deepInk": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0.094118, 0.082353, 0.070588],
        "hex": "#181512"
      }
    }
  },
  "font": {
    "family": {
      "$type": "fontFamily",
      "editorial": {
        "$value": "Newsreader"
      },
      "interface": {
        "$value": "Geist"
      }
    },
    "weight": {
      "$type": "fontWeight",
      "regular": {
        "$value": 400
      },
      "medium": {
        "$value": 500
      },
      "semibold": {
        "$value": 600
      }
    }
  }
}
